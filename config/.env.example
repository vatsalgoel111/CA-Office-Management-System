# CA Office CMS environment configuration example.
# Copy to .env only if local overrides are needed.

# Supported: development, testing, production
CA_CMS_ENV=development

# Supported: sqlite. Future: postgresql, mysql.
CA_CMS_DB_PROVIDER=sqlite

# SQLite database filename. Stored under the configured runtime data folder.
CA_CMS_DB_NAME=ca_office_cms.sqlite3

# Optional runtime root. Defaults to the project root in development.
# CA_CMS_RUNTIME_ROOT=C:\CAOfficeCMS

# Supported: DEBUG, INFO, WARNING, ERROR, CRITICAL
CA_CMS_LOG_LEVEL=DEBUG
CA_CMS_LOG_FILENAME=app.log

# Enable development diagnostics.
CA_CMS_DEBUG=true

# Future database URL for PostgreSQL/MySQL migrations.
# CA_CMS_DATABASE_URL=

